# ── Core ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (default is SQLite — uncomment for PostgreSQL) ───────────────────
# DATABASE_URL=postgres://user:password@localhost:5432/hub_db

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend # Uncomment for production to send real emails
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend # For development, prints emails to console
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=The Hub <your@gmail.com>

# ── Payments ──────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxx

# ── Redis (optional — for production caching) ─────────────────────────────────
# REDIS_URL=redis://127.0.0.1:6379/1